}

.log-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 400px;
}

.log-output {
  flex: 1;
  background: #1e1e1e;
  border-radius: 8px;
  padding: 15px;
  overflow-y: auto;
  font-family: 'Courier New', monospace;
  font-size: 13px;
  line-height: 1.6;
  max-height: 500px;
}

.empty-log {
  color: #666;
  text-align: center;
  padding: 40px;
}

.log-line {
  color: #d4d4d4;
  margin-bottom: 4px;
}

.results-section {
  margin-top: 20px;
}

.result-group {
  margin-bottom: 20px;
}

.result-title {
  font-size: 16px;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 10px;
}

.result-table {
  border: 1px solid #e0e0e0;
  border-radius: 6px;
  overflow: hidden;
}

.result-row {
  display: grid;
  grid-template-columns: 1fr 1fr 120px;
  padding: 10px 15px;
  border-bottom: 1px solid #f0f0f0;
}

.result-row:last-child {
  border-bottom: none;
}

.result-row.header {
  background: #f8f8f8;
